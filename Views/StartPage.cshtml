@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.StartPage>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
    Layout = "master.cshtml";
    var heroTitle = Model.HeroTitle;
    var heroText = Model.HeroText;
    var heroImages = Model.HeroImage;
}

<div class="relative h-screen w-full">
    @if (heroImages != null && heroImages.Count() > 0)
    {
        foreach (var image in heroImages)
        {
            <img src=" @image?.Url()" class="h-full w-full object-cover" style="border:2px solid blue;">
        }
    }

    <div class="absolute inset-0 z-10 grid grid-cols-1 md:grid-cols-2 items-center px-8" style="border:2px solid red;">
        <div style="border:2px solid red" ;>
            <div class="bg-white/30 backdrop-brightness-50 p-4 pl-4 pr-12 md:pl-8 md:pr-24 space-y-4">
                <h1 class="text-4xl font-bold">@heroTitle</h1>
                <p>@heroText</p>
                <a class="btn">Våra tjänster</a>
            </div>
        </div>
    </div>
    <div class="mb-5">
        @await Html.PartialAsync("~/Views/Shared/serviceList.cshtml")
    </div>
    <div class="mt-5">
        @await Html.PartialAsync("~/Views/Shared/ColorListComponent.cshtml")
    </div>
</div>
